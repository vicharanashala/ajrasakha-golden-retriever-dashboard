NODE_ENV=development
PORT=4000
CLIENT_ORIGIN=http://localhost:5173
# In production set these to the FastAPI service's Tailscale IP/hostname, e.g.
#   RETRIEVAL_API_V1_URL=http://100.x.x.x:8110/v1/gdb/search
# Leave as localhost for direct local development.
RETRIEVAL_API_V1_URL=http://localhost:8110/v1/gdb/search
RETRIEVAL_API_V2_URL=http://localhost:8110/v2/gdb/search-combined
RETRIEVAL_API_TIMEOUT_MS=90000
# SOCKS5 proxy URL exposed by `tailscaled` (default 127.0.0.1:1055).
# Empty/unset disables the proxy and falls back to direct fetch.
LANGGRAPH_SOCKS_URL=socks5://127.0.0.1:1055
ANSWER_SHORTENER_API_URL=http://100.100.108.43:8112/v1/answers/shorten
ANSWER_SHORTENER_API_KEY=
ANSWER_SHORTENER_TIMEOUT_MS=90000
ZOHO_ACCOUNTS_URL=https://accounts.zoho.com
ZOHO_SHEET_API_BASE=https://sheet.zoho.com
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_SHEET_RESOURCE_ID=
ZOHO_RETRIEVAL_WORKSHEET_NAME=Feedback
ZOHO_ANSWER_SHORTENER_WORKSHEET_NAME=Answer Shortener Feedback